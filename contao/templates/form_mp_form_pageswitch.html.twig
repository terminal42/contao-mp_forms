{% extends '@Contao/form_row.html.twig' %}

{% block field %}
    <button type="submit" name="{{ this.name }}" value="continue">{{ this.slabel }}</button>

    {% if this.canGoBack and this.mp_forms_backButton %}
        <button type="submit" name="{{ this.name }}" value="back" formnovalidate>
            {{ this.mp_forms_backButton }}
        </button>
    {% endif %}
{% endblock %}
